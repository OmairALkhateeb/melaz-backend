APP_NAME="Melaz Motors"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database -----------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=melaz
DB_USERNAME=root
DB_PASSWORD=

# --- Caching / queues / sessions ---------------------------------------------
# In production, switch to redis for all three.
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false      # set true in production (HTTPS only)

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail --------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Cloud storage (only if CARS_IMAGES_DISK=s3) -----------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Car listings ------------------------------------------------------------
CARS_DEFAULT_PER_PAGE=12
CARS_MAX_PER_PAGE=60
CARS_FILTER_CACHE_TTL=600

# Image storage. Set to "s3" (or any disk you configure in filesystems.php)
# to move uploads to cloud storage without code changes.
CARS_IMAGES_DISK=public
CARS_IMAGES_DIRECTORY=cars
CARS_IMAGES_MAX_SIZE_KB=5120
CARS_IMAGES_RESIZE_MODE=contain
CARS_IMAGES_RESIZE_WIDTH=1600
CARS_IMAGES_RESIZE_HEIGHT=1067

# --- Admin seed credentials (used by AdminUserSeeder) ------------------------
ADMIN_NAME="Site Admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="please-change-me"

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed frontend origins. Leave EMPTY = allow all
# (fine for local dev only). In production, set to your real domain(s):
#   CORS_ALLOWED_ORIGINS="https://melazmotors.com,https://www.melazmotors.com"
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGINS_PATTERNS=
CORS_MAX_AGE=86400

# --- Pusher (only if you wire real-time broadcasting later) ------------------
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
